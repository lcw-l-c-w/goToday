<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.co.gotoday.user.UserMapper">
	
	<!-- 카카오 -->
	<insert id="insertKakaoUser" parameterType="kr.co.gotoday.user.UserVO" useGeneratedKeys="true" keyProperty="user_id">
	    INSERT INTO user(
	    	email, name, registered_at, role, login_type
	    ) VALUES(#{kakao_email}, #{kakao_nickname}, NOW(), 0, 'K')
    </insert>
	
	<!-- 카카오 DB 중복 체크-->
	<select id="loginByEmail" parameterType="String" resultType="kr.co.gotoday.user.UserVO">
    	SELECT * FROM user WHERE email = #{email}
	</select>

	<!-- 로그인 -->
    <select id="login" parameterType="kr.co.gotoday.user.UserVO" resultType="kr.co.gotoday.user.UserVO">
        SELECT * FROM user WHERE email = #{email} AND password = MD5(#{password})
    </select>

    <!-- 회원가입 -->
    <insert id="register" parameterType="kr.co.gotoday.user.UserVO" useGeneratedKeys="true" keyProperty="user_id">
        INSERT INTO user (
        	email, password, name, gender, birthday
        	, phone_number, registered_at, role, login_type
        ) VALUES(#{email}, MD5(#{password}), #{name}, #{gender}, #{birthday}, #{phone_number}, NOW(), #{role}, 'L')
    </insert>

    <!-- 사용자 관심사 선택 -->
    <insert id="createUserTags" parameterType="kr.co.gotoday.user.UserTagVO">
        INSERT INTO user_tag(user_id, tag_id) 
        VALUES(#{user_id}, #{tag_id})
    </insert>

    <!-- 태그 이름으로 태그 id 찾기 -->
    <select id="findTagIdByName" parameterType="String" resultType="long">
        SELECT tag_id FROM tag WHERE tag_name = #{tagName}
    </select>
    
    <!-- 이메일 중복 체크 -->
    <select id="emailCheck" parameterType="String" resultType="Integer">
        SELECT COUNT(*) FROM user WHERE email = #{email}
    </select>
	
	<!-- 관리자 로그인 -->
    <select id="adminLogin" parameterType="kr.co.gotoday.user.UserVO" resultType="kr.co.gotoday.user.UserVO">
        SELECT 
        	admin_id AS user_id
        	, email
        	, password 
        FROM admin WHERE email = #{email} AND password = #{password}
    </select>
    
    <!-- 관심사 수정(사용자 태그 목록 확인) -->
	<select id="getUserTagNames" resultType="String">
	    SELECT t.tag_name
	    FROM user_tag ut
	    JOIN tag t ON ut.tag_id = t.tag_id
	    WHERE ut.user_id = #{userId}
	</select>

	<!-- 관심사 수정(사용자 태그 전체 삭제) -->
	<delete id="deleteUserTags">
	    DELETE FROM user_tag WHERE user_id = #{userId}
	</delete>
	
	<!-- 관심사 수정(사용자 태그 추가) -->
	<insert id="insertUserTag" parameterType="kr.co.gotoday.user.UserTagVO">
	    INSERT INTO user_tag (user_id, tag_id)
	    VALUES (#{user_id}, #{tag_id})
	</insert>
</mapper>